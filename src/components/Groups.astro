---
const groups = [
  {
    icon: `<rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>`,
    label: 'Angestellt',
    sub: 'Vollzeit · Teilzeit · Minijob',
  },
  {
    icon: `<line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><rect x="3" y="3" width="18" height="18"/>`,
    label: 'Öffentl. Dienst',
    sub: 'Beamte · TVöD · TV-L',
  },
  {
    icon: `<circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/>`,
    label: 'Selbstständig',
    sub: 'Gewerbe · Freischaffend',
  },
  {
    icon: `<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>`,
    label: 'Freier Beruf',
    sub: 'Versorgungswerk · Sonstige Freiberufler',
  },
];
---

<section aria-labelledby="groups-heading" class="py-20 px-6 border-t border-border bg-card/30">
  <div class="container max-w-6xl mx-auto">
    <div class="grid md:grid-cols-2 gap-12 items-center">

      <div>
        <p class="text-[11px] text-muted-foreground tracking-[5px] uppercase mb-4">Für wen</p>
        <h2 id="groups-heading" class="text-3xl sm:text-4xl font-semibold tracking-tight text-foreground mb-4">
          Jede Berufsgruppe.<br/>
          <em class="text-primary not-italic">Eigene Logik.</em>
        </h2>
        <p class="text-sm text-muted-foreground leading-relaxed mb-6">
          Ob Riester, Rürup, Pension oder Versorgungswerk — alterli erkennt deine Situation und
          berechnet nur das was für dich relevant ist.
        </p>
        <a href="#app"
          class="inline-flex items-center gap-2 bg-primary text-primary-foreground hover:bg-primary/90 text-sm font-medium px-5 py-2.5 rounded-md transition-colors">
          Eigene Analyse starten
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>

      <ul role="list" class="grid grid-cols-2 gap-px bg-border rounded-lg overflow-hidden">
        {groups.map((g) => (
          <li role="listitem"
            class="bg-card p-5 flex flex-col gap-2 hover:bg-accent/30 transition-colors group">
            <div class="w-7 h-7 rounded-md bg-primary/10 border border-primary/20 flex items-center justify-center text-primary flex-shrink-0" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                set:html={g.icon} />
            </div>
            <span class="text-sm font-medium text-foreground">{g.label}</span>
            <span class="text-[10px] text-muted-foreground leading-relaxed">{g.sub}</span>
            <div class="mt-auto pt-2">
              <div class="h-px w-5 bg-primary opacity-40 rounded-full"></div>
            </div>
          </li>
        ))}
      </ul>

    </div>
  </div>
</section>
