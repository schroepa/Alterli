---
const buildDate = new Date();
const standLabel = buildDate.toLocaleDateString('de-DE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const year = buildDate.getFullYear();
---
<footer class="border-t border-border py-10 px-6">
  <div class="container max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">

      <div>
        <a href="/" class="text-lg font-semibold tracking-tight text-foreground hover:text-primary transition-colors">
          alter<span class="text-primary">li</span>
        </a>
        <p class="text-[11px] text-muted-foreground mt-1">
          Ein Produkt von{' '}
          <a href="https://digipub.de" class="hover:text-foreground transition-colors underline underline-offset-2">
            DigiPub
          </a>
        </p>
      </div>

      <div class="text-[11px] text-muted-foreground leading-relaxed max-w-sm">
        Alle Berechnungen sind vereinfachte Schätzungen ohne Gewähr. Kein Ersatz für individuelle
        Finanz- oder Steuerberatung. Stand: {standLabel}.
      </div>

      <ul role="list" class="flex flex-col gap-1.5 text-[11px] text-muted-foreground">
        {['Keine Datenspeicherung', 'Alle Berechnungen lokal', 'Open Source geplant'].map(item => (
          <li class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
              class="text-primary flex-shrink-0" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            {item}
          </li>
        ))}
      </ul>
    </div>

    <div class="mt-8 pt-6 border-t border-border flex items-center justify-between flex-wrap gap-3">
      <span class="text-[10px] text-muted-foreground/50">© {year} DigiPub · alterli v1 Alpha</span>
      <span class="text-[10px] text-muted-foreground/50">Keine Anlageberatung im Sinne des WpHG</span>
    </div>
  </div>
</footer>
